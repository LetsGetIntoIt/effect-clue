		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"knip": "knip",
		"i18n:check": "node scripts/check-i18n-keys.mjs",
		"dev": "next dev",
		"build": "next build",
		"start": "next start"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/bigpopakap/effect-clue.git"
	},
	"keywords": [
		"Clue",
		"effect",
		"board",
		"game",
		"solver"
	],
	"author": "bigpopakap",
	"license": "UNLICENSED",
	"bugs": {
		"url": "https://github.com/bigpopakap/effect-clue/issues"
	},
	"homepage": "https://github.com/bigpopakap/effect-clue#readme",
	"dependencies": {
		"@radix-ui/react-alert-dialog": "1.1.15",
		"@radix-ui/react-popover": "1.1.15",
		"@radix-ui/react-tooltip": "1.2.8",
		"effect": "4.0.0-beta.50",
		"next": "16.2.4",
		"next-intl": "4.9.1",
		"react": "19.2.5",
		"react-dom": "19.2.5"
	},
	"devDependencies": {
		"@effect/language-service": "0.85.1",
		"@jest/globals": "29.6.4",
		"@tailwindcss/postcss": "4.2.2",
		"@types/jest": "29.5.4",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@typescript-eslint/eslint-plugin": "8.58.2",
		"@typescript-eslint/parser": "8.58.2",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint": "10.2.1",
		"eslint-plugin-i18next": "6.1.4",
		"jest": "29.6.4",
		"knip": "6.4.1",
		"postcss": "8.5.10",
		"tailwindcss": "4.2.2",
		"ts-jest": "29.1.1",
		"ts-node": "10.9.1",
		"typescript": "5.2.2"
	},
