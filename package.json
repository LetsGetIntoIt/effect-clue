{
	"name": "@bipgopakap/effect-clue",
	"version": "0.0.1",
	"description": "A solver for the board game Clue",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
