{
	"name": "@bipgopakap/effect-clue",
	"version": "0.0.1",
	"description": "A solver for the board game Clue",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.4",
	"engines": {
		"node": ">=22.12.0",
		"pnpm": ">=10.32.0"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"knip": "knip",
		"i18n:check": "node scripts/check-i18n-keys.mjs",
		"assert:no-dev-auth": "node scripts/assert-no-dev-auth.mjs",
		"assert:sw-emitted": "node scripts/assert-sw-emitted.mjs",
		"dev": "node scripts/dev.mjs",
		"build": "next build && serwist build",
		"build:offline-test": "pnpm build && pnpm start",
		"start": "next start",
		"db:up": "docker compose up -d postgres",
		"db:down": "docker compose down",
		"db:reset": "docker compose down -v && docker compose up -d postgres",
		"db:logs": "docker compose logs -f postgres",
		"db:psql": "docker compose exec postgres psql -U effect_clue -d effect_clue"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/bigpopakap/effect-clue.git"
	},
	"keywords": [
		"Clue",
		"effect",
		"board",
		"game",
		"solver"
	],
	"author": "bigpopakap",
	"license": "UNLICENSED",
	"bugs": {
		"url": "https://github.com/bigpopakap/effect-clue/issues"
	},
	"homepage": "https://github.com/bigpopakap/effect-clue#readme",
	"dependencies": {
		"@effect/opentelemetry": "4.0.0-beta.65",
		"@effect/platform-node": "4.0.0-beta.65",
		"@effect/sql-pg": "4.0.0-beta.65",
		"@opentelemetry/api": "1.9.1",
		"@opentelemetry/exporter-logs-otlp-http": "0.216.0",
		"@opentelemetry/exporter-metrics-otlp-http": "0.216.0",
		"@opentelemetry/exporter-trace-otlp-http": "0.216.0",
		"@opentelemetry/instrumentation": "0.216.0",
		"@opentelemetry/instrumentation-document-load": "0.61.0",
		"@opentelemetry/instrumentation-user-interaction": "0.60.0",
		"@opentelemetry/resources": "2.7.1",
		"@opentelemetry/sdk-logs": "0.216.0",
		"@opentelemetry/sdk-metrics": "2.7.1",
		"@opentelemetry/sdk-trace-base": "2.7.1",
		"@opentelemetry/sdk-trace-node": "2.7.1",
		"@opentelemetry/sdk-trace-web": "2.7.1",
		"@opentelemetry/semantic-conventions": "1.40.0",
		"@paralleldrive/cuid2": "3.3.0",
		"@radix-ui/react-dialog": "1.1.15",
		"@radix-ui/react-popover": "1.1.15",
		"@radix-ui/react-tooltip": "1.2.8",
		"@sentry/nextjs": "10.53.1",
		"@tanstack/query-async-storage-persister": "5.100.10",
		"@tanstack/react-query": "5.100.10",
		"@tanstack/react-query-persist-client": "5.100.10",
		"better-auth": "1.6.11",
		"canvas-confetti": "1.9.4",
		"effect": "4.0.0-beta.65",
		"lean-qr": "2.7.1",
		"motion": "12.38.0",
		"next": "16.2.6",
		"next-intl": "4.12.0",
		"pg": "8.20.0",
		"posthog-js": "1.373.5",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-youtube": "10.1.0",
		"server-only": "0.0.1",
		"web-vitals": "5.2.0"
	},
	"devDependencies": {
		"@effect/language-service": "0.85.1",
		"@effect/vitest": "4.0.0-beta.65",
		"@serwist/cli": "9.5.11",
		"@serwist/next": "9.5.11",
		"@tailwindcss/postcss": "4.2.4",
		"@tanstack/react-query-devtools": "5.100.10",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/canvas-confetti": "1.9.0",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@typescript-eslint/eslint-plugin": "8.59.3",
		"@typescript-eslint/parser": "8.59.3",
		"@vitest/coverage-v8": "4.1.6",
		"babel-plugin-react-compiler": "1.0.0",
		"esbuild": "0.28.0",
		"eslint": "10.4.0",
		"eslint-plugin-i18next": "6.1.4",
		"jsdom": "29.1.1",
		"knip": "6.14.1",
		"postcss": "8.5.14",
		"serwist": "9.5.11",
		"tailwindcss": "4.2.4",
		"typescript": "6.0.3",
		"vercel": "53.1.1",
		"vitest": "4.1.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp"
		]
	}
}
