# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies and build output
/node_modules/
dist/
dist-ssr
*.local

# Wrong package manager artefacts. This project uses pnpm (see
# `packageManager` in package.json) — accidental yarn / npm runs leave
# their state behind, but it must never land tracked. CI is pnpm-only,
# so a stray lockfile or .yarn cache would be a silent footgun.
/.yarn/
/yarn.lock
/.yarnrc
/.yarnrc.yml
/package-lock.json

# Next.js
.next/
out/
next-env.d.ts

# Serwist-emitted service worker artifacts — `public/sw.js` is
# regenerated on every production build by `serwist build` (the
# configurator-mode post-step). Source lives in `app/sw.ts`. Don't
# track the build output.
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map

# Environment files. Anything matching `.env` or `.env.*` carries
# real secrets and must never land in git. The committed template
# is `env.example` (no leading dot) — Vercel's deploy log warns
# whenever it sees a `.env*` file in the source checkout, so we
# keep the canonical template under a name that doesn't match the
# pattern.
.env
.env.*

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/*.code-snippetss

# IntelliJ
.idea

# Annoying files
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temp files
/.tscache/
/*.tmp.*
/.eslintcache
/*.log
/*.tsbuildinfo

# Locally linked dependencies
# See https://www.npmjs.com/package/link
/link.config.json

# Jest
/coverage/

# Claude Code worktrees
.claude/worktrees/

# Codex worktrees
.codex/worktrees/
.vercel
.env*.local
